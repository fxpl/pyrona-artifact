
# Resolve snapshot paths from this env file location so the file is portable
# across host and container workspaces. Callers can still override any path.
ARTIFACT_ROOT="$(
  cd "$(dirname "${BASH_SOURCE[0]:-${0}}")" \
  && pwd -P
)"
_PYTHON_BIN_SUFFIX=""
case "$(uname -s)" in
  CYGWIN*|MINGW*|MSYS*|Darwin)
    _PYTHON_BIN_SUFFIX=".exe"
    ;;
esac

export BASELINE_PYTHON_DIR="${ARTIFACT_ROOT}/snapshots/cpython-baseline"
export PATCHED_PYTHON_DIR="${ARTIFACT_ROOT}/snapshots/cpython-patched"

export BASELINE_BUILD_DIR="${ARTIFACT_ROOT}/build/cpython-baseline"
export PATCHED_BUILD_DIR="${ARTIFACT_ROOT}/build/cpython-patched"

export BASELINE_PYTHON_ENV="${ARTIFACT_ROOT}/build/venv-baseline"
export PATCHED_PYTHON_ENV="${ARTIFACT_ROOT}/build/venv-patched"
export STABLE_PYTHON_ENV="${ARTIFACT_ROOT}/build/venv-stable"
export BASELINE_PYTHON_ENV_ACTIVATE="$BASELINE_PYTHON_ENV/bin/activate"
export PATCHED_PYTHON_ENV_ACTIVATE="$PATCHED_PYTHON_ENV/bin/activate"
export STABLE_PYTHON_ENV_ACTIVATE="$STABLE_PYTHON_ENV/bin/activate"

export BASELINE_PYTHON_BIN="${BASELINE_BUILD_DIR}/python${_PYTHON_BIN_SUFFIX}"
export PATCHED_PYTHON_BIN="${PATCHED_BUILD_DIR}/python${_PYTHON_BIN_SUFFIX}"
export STABLE_PYTHON_BIN="$STABLE_PYTHON_ENV/bin/python"

# Stop streamlit from collecting usage data (Why is this the default to begin with...)
export STREAMLIT_BROWSER_GATHER_USAGE_STATS=0

unset _PYTHON_BIN_SUFFIX
